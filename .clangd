---
 CompileFlags:
   Add: [
     "-Iglfw-3.4.bin.WIN64/include",
     #this for roo workspace dir to enable standard glm headers includ with glm/glm.hpp as the flag targets the folder that contains the headers folder
     "-I.",
     "-std=c++20", # this fixes the mismatch that clangd-cl that takes the standard from the CMakeLists.txt and the clangd language server that takes the standard from this file
     "-IC:/VulkanSDK/1.3.296.0/include"
   ]